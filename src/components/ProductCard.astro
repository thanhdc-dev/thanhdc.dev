---
interface Props {
  id: number;
  number: string;
  total: string;
  title: string;
  url: string;
  domain: string;
  description: string;
  tags: string[];
  cardColor: string;
  accentColor: string;
  previewUrl: string;
  animationDelay: string;
}

const {
  number,
  total,
  title,
  url,
  domain,
  description,
  tags,
  cardColor,
  accentColor,
  previewUrl,
  animationDelay,
} = Astro.props;
---

<article
  class:list={[
    cardColor,
    'relative bg-surface border border-border overflow-hidden transition-all duration-300 sm:hover:-translate-y-0.5 sm:hover:border-muted mb-4 rounded-lg',
    animationDelay,
  ]}
>
  <!-- Preview -->
  <div class="preview-fade relative w-full bg-bg border-b border-border overflow-hidden" style="aspect-ratio: 16/7">
    <iframe class="iframe-scale" src={previewUrl} title={`${title} preview`} loading="lazy" scrolling="no"> </iframe>
  </div>

  <!-- Body -->
  <div class="p-6 sm:p-8 flex flex-col sm:flex-row sm:items-start gap-5 sm:gap-8">
    <div class="flex-1 min-w-0">
      <p class="font-mono text-[10px] tracking-[0.2em] text-muted uppercase mb-2">
        {number} / {total}
      </p>
      <h2 class="font-serif font-light text-bright text-2xl sm:text-3xl leading-tight tracking-tight">
        <a href={url} target="_blank" rel="noopener" class:list={[`sm:hover:text-${accentColor} transition-colors duration-200`]}>
          {title}
        </a>
      </h2>
      <span class="inline-block mt-1 font-mono text-[11px] tracking-wide text-dim">
        {domain}
      </span>
      <p class="mt-3 font-mono text-[13px] text-dim leading-[1.75] max-w-lg">
        {description}
      </p>
      <div class="flex flex-wrap gap-1.5 mt-4">
        {
          tags.map((tech) => (
            <span class="font-mono text-[10px] tracking-[0.12em] uppercase px-2.5 py-1 border border-border text-dim rounded-sm sm:hover:border-muted sm:hover:text-base transition-colors duration-200">
              {tech}
            </span>
          ))
        }
      </div>
    </div>

    <div class="flex sm:flex-col items-center sm:items-end gap-2 shrink-0">
      <a
        href={url}
        target="_blank"
        rel="noopener"
        aria-label={`Truy cập ${title}`}
        class:list={[`inline-flex items-center gap-2 px-4 py-2.5 font-mono text-[11px] tracking-[0.12em] uppercase whitespace-nowrap border border-${accentColor} text-${accentColor} sm:hover:bg-${accentColor} sm:hover:text-bg transition-all duration-200`]}
      >
        Truy cập
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 10L10 2M10 2H5M10 2v5"></path>
        </svg>
      </a>
    </div>
  </div>
</article>
